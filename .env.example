# Yoruba Heritage Park server environment
#
# Copy this file to .env for local development. Do not commit real .env files.
# Database variables intentionally do not use the VITE_ prefix because they must
# never be exposed to browser bundles.

# Application mode. Leave mock until the MySQL backend is deliberately connected.
ADMIN_DATA_SOURCE=mock

# Node runtime mode.
NODE_ENV=development

# MySQL or MariaDB connection settings. Required only for db:* commands or when
# ADMIN_DATA_SOURCE=mysql.
DATABASE_HOST=
DATABASE_PORT=3306
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_CONNECTION_LIMIT=5
DATABASE_SSL_MODE=disabled
